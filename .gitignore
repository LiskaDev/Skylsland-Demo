# =============== #
#  Unity .gitignore
# =============== #

# Unity 自动生成的大文件夹（几百MB~几GB，绝对不要上传）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# 第三方素材资源（体积大，可能有版权限制）
/Assets/ThirdParty/

# Memory-mapped files
/MemoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset auto-generated
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated meta files
*.pidb
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# VS / Rider IDE
.vs/
.idea/
*.csproj
*.sln

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
